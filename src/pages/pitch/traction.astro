---
import PitchLayout from '../../layouts/PitchLayout.astro';
---

<PitchLayout slug="traction">
  <h1 class="slide-headline">And we're already doing it. Profitably.</h1>

  <div class="split">
    <div class="split-block">
      <p class="slide-label">Live Trading</p>
      <p class="stat-number">75% win rate</p>
      <p class="slide-body-small" style="margin-top: 16px;">60 days, 500+ trades on Kalshi weather markets. Real money.</p>
    </div>
    <div class="split-block">
      <p class="slide-label">How we trade</p>
      <p class="slide-body-small">We use custom ML models to trade weather contracts on Kalshi. Fully automated, running every single day.</p>
    </div>
  </div>
</PitchLayout>
