---
import BaseLayout from './BaseLayout.astro';
import PitchNav from '../components/PitchNav.astro';
import '../styles/pitch.css';
import { getSlideBySlug } from '../data/pitch-slides';

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const slide = getSlideBySlug(slug);
if (!slide) throw new Error(`Unknown slide: ${slug}`);
---

<BaseLayout title={slide.title} description={slide.description}>
  <div class="slide">
    <slot />
  </div>
  <PitchNav slug={slug} />
  <script src="../scripts/pitch-nav.ts"></script>
  <script is:inline>
    // Nudge nav arrows after 10s idle
    (function() {
      var timer;
      function startTimer() {
        clearTimeout(timer);
        timer = setTimeout(function nudge() {
          var btns = document.querySelectorAll('.slide-nav-btn-sm:not(.disabled)');
          btns.forEach(function(el) {
            el.classList.remove('nudge');
            void el.offsetWidth;
            el.classList.add('nudge');
          });
          timer = setTimeout(nudge, 10000);
        }, 10000);
      }
      startTimer();
      document.addEventListener('mousemove', startTimer);
      document.addEventListener('keydown', startTimer);
      document.addEventListener('scroll', startTimer);
    })();
  </script>
</BaseLayout>
