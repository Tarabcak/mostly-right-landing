---
/**
 * Docs topbar right cluster — version tag + GitHub text link.
 *
 * Replaces Starlight's default SocialIcons slot (see `components.SocialIcons`
 * override in astro.config.mjs) so the docs header matches the Claude
 * design screenshot: a small mono version badge, then "GitHub ↗" as a
 * text link (no icon).
 *
 * Version source: openapi.json's info.version — the SDK/API version these
 * docs document. Synced from mostlyright@main by the docs-sync workflow
 * (Sprint 2m-s1). Previously sourced from this repo's package.json, which
 * tracked the landing-site deploy version and was confusing — a reader
 * seeing "v0.4.2" at the top of /docs/ naturally assumed the SDK was at
 * 0.4.x when it was actually at 0.13.x.
 */
import openapi from '../../content/docs/docs/_generated/openapi.json';
const apiVersion = openapi?.info?.version ?? '';
---

<div class="docs-top-right">
  <span class="docs-version" aria-label={`Version ${apiVersion}`}>v{apiVersion}</span>
  <a class="docs-gh-link" href="https://github.com/Tarabcak/mostlyright" rel="noopener">
    GitHub<span aria-hidden="true"> ↗</span>
  </a>
</div>

<style>
  .docs-top-right {
    display: flex;
    align-items: center;
    gap: 18px;
  }
  .docs-version {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.45);
    font-variant-numeric: tabular-nums;
  }
  .docs-gh-link {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    text-transform: none;
    transition: color 0.15s ease;
  }
  .docs-gh-link:hover {
    color: #fff;
  }
</style>
