---
/**
 * Docs AsToolsPreview — `client.as_tools()` card grid.
 *
 * Handoff Modules.jsx §AsToolsPreview:
 *   2x2 grid of tool cards (snapshot, candles, book_snapshot, markets).
 *   Each card: name + N params, description, tag chips for params.
 *   Header: "client.as_tools() → Anthropic tool definitions" · N tools.
 *   Static display, no interactivity.
 *
 * Usage in MDX:
 *   import AsToolsPreview from '@components/docs/AsToolsPreview.astro';
 *   <AsToolsPreview />
 *
 * Pass custom tools via prop to reflect the actual SDK surface for a
 * given page. Defaults match handoff sample set.
 */

export interface Tool {
  name: string;
  desc: string;
  params: string[];
}

export interface Props {
  tools?: Tool[];
  signature?: string;
}

const DEFAULT_TOOLS: Tool[] = [
  {
    name: 'observations',
    desc: 'Historical hourly station observations, point-in-time correct.',
    params: ['station', 'from_date', 'to_date', 'as_of'],
  },
  {
    name: 'forecasts',
    desc: 'NWS MOS and Open-Meteo forecasts for a station and window.',
    params: ['station', 'model', 'issued_at'],
  },
  {
    name: 'climate',
    desc: 'Daily climate aggregates (min / max / mean / precip).',
    params: ['station', 'from_date', 'to_date'],
  },
  {
    name: 'stations',
    desc: 'List available stations with lat/lon and covered date ranges.',
    params: [],
  },
];

const {
  tools = DEFAULT_TOOLS,
  signature = 'client.as_tools() → Anthropic tool definitions',
} = Astro.props;
---

<div class="docs-astools">
  <div class="docs-astools-header">
    <span class="docs-astools-signature">{signature}</span>
    <span class="docs-astools-count">{tools.length} tools</span>
  </div>
  <div class="docs-astools-grid">
    {
      tools.map((t) => (
        <div class="docs-astools-card">
          <div class="docs-astools-card-head">
            <code class="docs-astools-name">{t.name}</code>
            <span class="docs-astools-params-count">
              {t.params.length} {t.params.length === 1 ? 'param' : 'params'}
            </span>
          </div>
          <p class="docs-astools-desc">{t.desc}</p>
          {t.params.length > 0 && (
            <div class="docs-astools-chips">
              {t.params.map((p) => (
                <span class="docs-astools-chip">{p}</span>
              ))}
            </div>
          )}
        </div>
      ))
    }
  </div>
</div>

<style>
  .docs-astools {
    border: 1px solid rgba(255, 255, 255, 0.08);
    margin: 24px 0;
    background: #0e0e0e;
  }
  .docs-astools-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
  }
  .docs-astools-count {
    color: rgba(255, 255, 255, 0.28);
  }
  .docs-astools-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: rgba(255, 255, 255, 0.08);
  }
  .docs-astools-card {
    background: #080808;
    padding: 14px 16px;
  }
  .docs-astools-card-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
  }
  .docs-astools-name {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 13px;
    font-weight: 600;
    color: #ffffff;
    background: transparent;
    border: 0;
    padding: 0;
  }
  .docs-astools-params-count {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10px;
    color: rgba(255, 255, 255, 0.28);
    letter-spacing: 0.08em;
    white-space: nowrap;
  }
  .docs-astools-desc {
    margin: 6px 0 10px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.6);
  }
  .docs-astools-chips {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .docs-astools-chip {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10px;
    padding: 2px 6px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: rgba(255, 255, 255, 0.6);
    letter-spacing: 0.04em;
  }

  @media (max-width: 720px) {
    .docs-astools-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
