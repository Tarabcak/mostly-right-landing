---
/**
 * Docs Head — overrides Starlight's default <head> output.
 *
 * Starlight emits title, description, og:title/description/type/url by
 * default but NOT og:image, twitter:image, twitter:title, or
 * twitter:description. We render Starlight's default tag array first,
 * then append the missing Open Graph + Twitter tags pointing at the
 * Satori-generated OG PNG for this page.
 *
 * The OG PNG lives at `/og/{entry.id}.png` — generated at build time
 * by `src/pages/og/[...slug].png.ts`, which enumerates every entry in
 * the docs collection.
 *
 * Wired via astro.config.mjs `components.Head`.
 */
const { head, entry } = Astro.locals.starlightRoute;

// entry.id under docsLoader is the slug path ("docs/introduction", etc.).
// Fallback to the static landing OG if for some reason the slug is empty
// (starlight-openapi runtime pages don't have a content-collection id).
const ogPath = entry.id ? `/og/${entry.id}.png` : '/og-image.png';
const ogUrl = new URL(ogPath, Astro.site);

const title = entry.data.title;
const description = entry.data.description ?? '';
---

{head.map(({ tag: Tag, attrs, content }) => <Tag {...attrs} set:html={content} />)}

<meta property="og:image" content={ogUrl.toString()} />
<meta name="twitter:image" content={ogUrl.toString()} />
<meta name="twitter:title" content={title} />
{description && <meta name="twitter:description" content={description} />}
