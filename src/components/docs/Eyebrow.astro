---
/**
 * Docs Eyebrow — uppercase mono label above H1.
 *
 * Handoff §2 Content Column spec: uppercase, 11px, letter-spacing .14em,
 * color rgba(255,255,255,.28), 20px below.
 *
 * Usage inside an MDX page:
 *   import Eyebrow from '@components/docs/Eyebrow.astro';
 *   <Eyebrow>Get started</Eyebrow>
 */
---

<p class="docs-eyebrow">
  <slot />
</p>

<style>
  .docs-eyebrow {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.28);
    margin: 0 0 20px;
  }
</style>
