---
/**
 * Docs Diff — before/after side-by-side code block.
 *
 * Handoff Modules.jsx §Diff(before, after):
 *   2-column grid, 1px center gutter, 1px outer border.
 *   Left (bad):  header in --docs-caution, label customizable
 *   Right (good): header in --docs-accent-live, label customizable.
 *   Pre-formatted code body, no syntax highlighting by default —
 *   pair with Starlight code fences for themed syntax inside
 *   via <code> children if richer rendering is needed.
 *
 * Usage in MDX:
 *   import Diff from '@components/docs/Diff.astro';
 *   <Diff
 *     beforeLabel="Without Mostly Right"
 *     afterLabel="With Mostly Right"
 *     before={`...`}
 *     after={`...`}
 *   />
 */

export interface Props {
  before: string;
  after: string;
  beforeLabel?: string;
  afterLabel?: string;
}

const {
  before,
  after,
  beforeLabel = 'Without Mostly Right',
  afterLabel = 'With Mostly Right',
} = Astro.props;
---

<div class="docs-diff">
  <div class="docs-diff-col is-before">
    <div class="docs-diff-head">{beforeLabel}</div>
    <pre class="docs-diff-body">{before}</pre>
  </div>
  <div class="docs-diff-col is-after">
    <div class="docs-diff-head">{afterLabel}</div>
    <pre class="docs-diff-body">{after}</pre>
  </div>
</div>

<style>
  .docs-diff {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.08);
    margin: 20px 0;
  }
  .docs-diff-col {
    background: #080808;
    min-width: 0;
  }
  /* Kill Starlight's markdown rhythm rule adding 16px margin-top
     to the second grid cell. Both columns should sit flush. */
  .docs-diff-col,
  .docs-diff-col > *,
  .docs-diff-body {
    margin-top: 0 !important;
  }
  .docs-diff-head {
    padding: 10px 14px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .docs-diff-col.is-before .docs-diff-head {
    color: #f87171;
  }
  .docs-diff-col.is-after .docs-diff-head {
    color: #4ade80;
  }
  .docs-diff-body {
    margin: 0;
    padding: 14px 16px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.78);
    overflow: auto;
    white-space: pre;
    background: transparent;
    border: 0;
    font-feature-settings: 'ss01', 'cv11';
  }

  @media (max-width: 720px) {
    .docs-diff {
      grid-template-columns: 1fr;
    }
  }
</style>
