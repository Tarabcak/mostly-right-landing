---
/**
 * Docs PageTitle — replaces Starlight's default <h1> header.
 *
 * Renders the optional `eyebrow` frontmatter field above the page
 * title, matching handoff §2 Content Column spec (uppercase mono
 * 11px eyebrow, Funnel Display 56px H1, 24px gap below).
 *
 * Wired via astro.config.mjs `components.PageTitle`.
 */
const { entry } = Astro.locals.starlightRoute;
const title = entry.data.title;
const eyebrow = (entry.data as { eyebrow?: string }).eyebrow;
---

{eyebrow && <p class="docs-page-eyebrow">{eyebrow}</p>}
<h1 id="_top" class="docs-page-title">{title}</h1>

<style>
  .docs-page-eyebrow {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.28);
    margin: 0 0 20px;
  }
  .docs-page-title {
    font-family: 'Funnel Display', ui-sans-serif, system-ui, sans-serif;
    font-weight: 400;
    font-size: clamp(40px, 4.4vw, 56px);
    line-height: 1.02;
    letter-spacing: -0.035em;
    color: #ffffff;
    margin: 0 0 24px;
  }
</style>
