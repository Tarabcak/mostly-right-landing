---
import Nav from '../Nav.astro';
---

<div class="w-hero-wrapper">
  <canvas id="waveCanvas" aria-hidden="true"></canvas>
  <Nav />
  <div class="w-hero">
    <div class="w-hero-grid">
      <div class="w-hero-left">
        <p class="w-hero-eyebrow"><span class="live-dot" aria-hidden="true"></span>Coming Soon</p>
        <h1>The complete weather SDK for prediction markets.</h1>
        <p class="w-hero-sub">Observations, forecasts, satellite, and settlement. All the data behind every Kalshi and Polymarket weather contract. Built for AI agents and&nbsp;quants.</p>
        <div class="w-hero-ctas">
          <a href="#early-access" class="w-btn">Join the waitlist</a>
        </div>
      </div>

      <div class="w-terminal">
        <div class="w-terminal-bar">
          <span class="w-terminal-title">CHI &middot; HIGH &middot; 2026-04-18 &middot; 18:00Z</span>
          <span class="w-terminal-live">
            <span class="live-dot" aria-hidden="true"></span>LIVE
          </span>
        </div>
        <pre class="w-terminal-body"><span class="w-term-muted">$ mostlyright snapshot("CHI", as_of="2026-04-18T18:00:00Z")</span>

kalshi       <span class="w-term-num">0.62</span>       <span class="w-term-muted"># KMDW &middot; bid .61 ask .63 &middot; vol 412k</span>
polymarket   <span class="w-term-num">0.59</span>       <span class="w-term-muted"># KORD &middot; diff station, same schema</span>

NBM          <span class="w-term-num">68&deg;F</span>       <span class="w-term-muted"># 06Z &middot; ensemble blend</span>
GFS          <span class="w-term-num">66&deg;F</span>       <span class="w-term-muted"># 00Z &middot; global</span>
HRRR         <span class="w-term-num">69&deg;F</span>       <span class="w-term-muted"># 17Z &middot; hourly convective</span>
ECMWF        <span class="w-term-num">67&deg;F</span>       <span class="w-term-muted"># 00Z &middot; european</span>

KMDW         <span class="w-term-num">66.2&deg;F</span>     <span class="w-term-muted"># dewpoint 54.1&deg;F &middot; RH 65% &middot; T-group</span>
KORD         <span class="w-term-num">65.8&deg;F</span>     <span class="w-term-muted"># dewpoint 53.9&deg;F &middot; RH 66% &middot; T-group</span>

window       <span class="w-term-num">2026-04-18</span> <span class="w-term-muted"># LST (CST) &middot; midnight&rarr;midnight</span>
settles_on   <span class="w-term-num">NWS CLI</span>    <span class="w-term-muted"># pending 04-19 10:00 CT</span>
version      <span class="w-term-num">v0.4.2</span>     <span class="w-term-muted"># 78y history &middot; reproducible</span></pre>
      </div>
    </div>
  </div>
</div>
