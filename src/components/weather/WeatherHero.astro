---
import Nav from '../Nav.astro';
---

<div class="w-hero-wrapper">
  <canvas id="waveCanvas" aria-hidden="true"></canvas>
  <Nav />
  <div class="w-hero">
    <div class="w-hero-grid">
      <div class="w-hero-left">
        <p class="w-hero-eyebrow"><span class="live-dot" aria-hidden="true"></span>Coming Soon</p>
        <h1>The complete weather SDK for prediction markets.</h1>
        <p class="w-hero-sub">Observations, forecasts, satellite, and settlement. All the data behind every Kalshi and Polymarket weather contract. Built for AI agents and&nbsp;quants.</p>
        <div class="w-hero-ctas">
          <a href="#early-access" class="w-btn">Join the waitlist</a>
        </div>
      </div>

      <div class="w-terminal">
        <div class="w-terminal-bar">
          <span class="w-terminal-title">KNYC &middot; HIGH &middot; 2026-04-18</span>
          <span class="w-terminal-live">
            <span class="live-dot" aria-hidden="true"></span>LIVE
          </span>
        </div>
        <pre class="w-terminal-body"><span class="w-term-muted">$ mostlyright snapshot("NYC", as_of="2026-04-18T18:00:00Z")</span>

kalshi       <span class="w-term-num">0.62</span>         <span class="w-term-muted"># bid .61 ask .63 &middot; vol 412k</span>
polymarket   <span class="w-term-num">0.59</span>         <span class="w-term-muted"># same contract &middot; unified pair</span>
forecast     <span class="w-term-num">71&deg;F</span>         <span class="w-term-muted"># NBM 06Z &middot; +GFS/HRRR/ECMWF</span>
observed     <span class="w-term-num">69.3&deg;F</span>       <span class="w-term-muted"># IEM T-group &middot; as_of=18Z</span>
history      <span class="w-term-num">1948 &rarr; live</span>  <span class="w-term-muted"># 78y &middot; same schema backtest = live</span>
settles_on   <span class="w-term-num">NWS CLI</span>      <span class="w-term-muted"># LST-aware &middot; pending 04-19 10:00 ET</span>
version      <span class="w-term-num">v0.4.2</span>       <span class="w-term-muted"># reproducibility token</span></pre>
      </div>
    </div>
  </div>
</div>
