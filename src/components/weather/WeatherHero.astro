---
import Nav from '../Nav.astro';
---

<div class="w-hero-wrapper">
  <canvas id="waveCanvas" aria-hidden="true"></canvas>
  <Nav />
  <div class="w-hero">
    <div class="w-hero-grid">
      <div class="w-hero-left">
        <p class="w-hero-eyebrow"><span class="live-dot" aria-hidden="true"></span>Coming Soon</p>
        <h1>The complete weather SDK for prediction markets.</h1>
        <p class="w-hero-sub">Observations, forecasts, satellite, and settlement. All the data behind every Kalshi and Polymarket weather contract. Built for AI agents and&nbsp;quants.</p>
        <div class="w-hero-ctas">
          <a href="#early-access" class="w-btn">Join the waitlist</a>
          <a href="/docs/" class="w-text-link">Read the docs <span class="w-text-link-arrow" aria-hidden="true">&rarr;</span></a>
        </div>
      </div>

      <div class="w-terminal">
        <div class="w-terminal-bar">
          <span class="w-terminal-title">CHICAGO &middot; HIGH &middot; 2026-04-18 &middot; 18:00 UTC</span>
          <span class="w-terminal-live">
            <span class="live-dot" aria-hidden="true"></span>LIVE
          </span>
        </div>
        <pre class="w-terminal-body"><span class="w-term-muted">$ mostlyright.snapshot("Chicago")
# "Will Chicago hit 68&deg;F today?"</span>

<span class="w-term-muted"># THE MARKETS</span>
Kalshi        <span class="w-term-num">0.62</span>     62% yes    settles at Midway
Polymarket    <span class="w-term-num">0.59</span>     59% yes    settles at O'Hare

<span class="w-term-muted"># THE FORECAST &mdash; 4-model ensemble</span>
NBM  <span class="w-term-num">68&deg;F</span>     GFS  <span class="w-term-num">66&deg;F</span>     HRRR  <span class="w-term-num">69&deg;F</span>     ECMWF  <span class="w-term-num">67&deg;F</span>

<span class="w-term-muted"># LIVE AT BOTH SETTLEMENT STATIONS</span>
Midway (KMDW)   <span class="w-term-num">66.2&deg;F</span>   dewpoint <span class="w-term-num">54&deg;F</span>   humidity <span class="w-term-num">65%</span>
O'Hare (KORD)   <span class="w-term-num">65.8&deg;F</span>   dewpoint <span class="w-term-num">54&deg;F</span>   humidity <span class="w-term-num">66%</span>

<span class="w-term-muted"># HOW IT SETTLES</span>
Window        tonight, midnight &rarr; midnight CT
Source        NWS Climate Daily (~10 AM CT tomorrow)
Reproducible  every query pinned to a <span class="w-term-num">data_version</span> token</pre>
      </div>
    </div>
  </div>
</div>
